{
  "name": "diffable-html-snapshot",
  "type": "module",
  "version": "0.2.0",
  "packageManager": "pnpm@11.6.0",
  "description": "Making HTML diffs readable for tests",
  "author": "ocavue <ocavue@gmail.com>",
  "license": "MIT",
  "funding": "https://github.com/sponsors/ocavue",
  "homepage": "https://github.com/ocavue/diffable-html-snapshot#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/ocavue/diffable-html-snapshot.git"
  },
  "bugs": "https://github.com/ocavue/diffable-html-snapshot/issues",
  "keywords": [],
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./snapshot-serializer": {
      "types": "./dist/snapshot-serializer.d.ts",
      "import": "./dist/snapshot-serializer.js",
      "default": "./dist/snapshot-serializer.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsdown",
    "lint": "eslint .",
    "fix": "eslint --fix . && prettier --write .",
    "test": "pnpm run build && pnpm run test:src && pnpm run test:e2e",
    "test:src": "vitest run ./src",
    "test:e2e": "pnpm --filter \"e2e-*\" --sequential test",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "htmlparser2": "^12.0.0"
  },
  "devDependencies": {
    "@ocavue/eslint-config": "^4.8.1",
    "@ocavue/tsconfig": "^0.7.1",
    "@types/node": "^24.0.0",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
